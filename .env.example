# Supabase Configuration
NEXT_PUBLIC_SUPABASE_URL=your_supabase_project_url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key

# Gemini API (for Monica AI Chat and Main Chat)
GEMINI_API_KEY=your_gemini_api_key

# OpenRouter API (Fallback cuando Gemini falla)
# Obtén tu API key en: https://openrouter.ai/keys
OPENROUTER_API_KEY=your_openrouter_api_key

# E2B API (Code Execution Sandbox for Paytony Module)
E2B_API_KEY=your_e2b_api_key

# Supabase Service Role Key (required for /api/chat endpoint)
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# Nylas API (Calendar & Email Integration)
NYLAS_API_KEY=your_nylas_api_key
NYLAS_API_URI=https://api.us.nylas.com
NYLAS_CLIENT_ID=your_nylas_client_id
NEXT_PUBLIC_NYLAS_CLIENT_ID=your_nylas_client_id
# Callback URL — MUST match a Callback URI registered in Nylas Dashboard
# Example: https://your-app.netlify.app/api/nylas/callback
NYLAS_CALLBACK_URL=https://conectado-urpeailab.netlify.app/api/nylas/callback

# Firecrawl API (Deep Research / Web Scraping)
FIRECRAWL_API_KEY=your_firecrawl_api_key

# OpenAI API (Voice Transcription)
OPENAI_API_KEY=your_openai_api_key
